# =========================
# AI Wardrobe Environment
# Copy this file to `.env`
# =========================

# -------------------------
# App
# -------------------------
APP_NAME=ai-wardrobe
APP_ENV=development


# -------------------------
# Frontend / Web
# Development: keep localhost
# Production: replace with your real HTTPS domain
# -------------------------
NEXT_PUBLIC_APP_NAME=AI Wardrobe
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000


# -------------------------
# Backend
# BACKEND_PUBLIC_BASE_URL is the public HTTPS address of your backend API.
# Example production value:
# BACKEND_PUBLIC_BASE_URL=https://api.yourdomain.com
# -------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_BASE_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=sqlite:///./data/ai_wardrobe.db


# -------------------------
# Mini Program / Mobile Client
# TARO_APP_API_BASE_URL should point to your backend API.
# Production should be HTTPS and normally match BACKEND_PUBLIC_BASE_URL.
# -------------------------
TARO_APP_API_BASE_URL=http://localhost:8000


# -------------------------
# Local-first storage
# -------------------------
LOCAL_STORAGE_ROOT=./backend/data/assets
MODEL_TRAINING_DIR=./model_training


# -------------------------
# Supabase
# You already confirmed the project URL below.
# Fill ANON KEY and SERVICE ROLE KEY from:
# Supabase Dashboard -> Project Settings -> API
# -------------------------
SUPABASE_URL=https://soeiaoojctyoxibvibjc.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=wardrobe-assets
SUPABASE_SYNC_TABLE=clothing_items


# -------------------------
# Cache / Queue / Future async expansion
# -------------------------
REDIS_URL=redis://localhost:6379/0


# -------------------------
# Optional S3-compatible object storage
# Keep as local/default if you are not using MinIO yet.
# -------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-wardrobe


# -------------------------
# LLM / model platform basics
# -------------------------
OPENAI_API_KEY=
VLLM_BASE_URL=
QWEN_MODEL_NAME=Qwen2.5-7B-Instruct


# -------------------------
# Model routing
# Source of truth can stay in backend/core/local_model.py
# MODEL_USE_LOCAL_DEFAULT=true means:
# prefer local logic unless a feature-specific override says otherwise
#
# If you want .env to hard override one feature, uncomment the line you need.
# Example:
# MODEL_USE_LOCAL_LLM_RECOMMENDER=false
# -------------------------
MODEL_USE_LOCAL_DEFAULT=true
# MODEL_USE_LOCAL_LLM_RECOMMENDER=false
# MODEL_USE_LOCAL_IMAGE_CLEANUP=false
# MODEL_USE_LOCAL_CLASSIFIER=false
# MODEL_USE_LOCAL_MULTIMODAL_READER=false
# MODEL_USE_LOCAL_VIRTUAL_TRYON=false
# MODEL_USE_LOCAL_PRODUCT_RENDERER=false
# MODEL_USE_LOCAL_AVATAR_BUILDER=false


# -------------------------
# AI cleanup pipeline
# Used for image cleanup / background removal adapter
# -------------------------
AI_CLEANUP_API_URL=
AI_CLEANUP_API_KEY=
AI_CLEANUP_TIMEOUT_SECONDS=45


# -------------------------
# Weather
# Built-in tomorrow assistant currently uses Open-Meteo by default.
# No API key is required for the current demo flow.
# -------------------------


# -------------------------
# API-first AI worker adapters
# Fill these after your own workers are deployed.
# If blank, corresponding features fall back to local/demo logic.
# -------------------------
AI_DEMO_ADAPTER_TIMEOUT_SECONDS=8
LLM_RECOMMENDER_API_URL=
IMAGE_PROCESSOR_API_URL=
CLASSIFIER_API_URL=
MULTIMODAL_READER_API_URL=
VIRTUAL_TRYON_API_URL=
PRODUCT_RENDERER_API_URL=
AVATAR_BUILDER_API_URL=


# -------------------------
# WeChat Mini Program
# Fill AppID / AppSecret from:
# 微信公众平台 -> 开发 -> 开发管理 -> 开发设置
#
# Important:
# WECHAT_MINIPROGRAM_REQUEST_DOMAIN should normally be your backend API HTTPS domain,
# not just the Supabase URL.
# Example production value:
# WECHAT_MINIPROGRAM_REQUEST_DOMAIN=https://api.yourdomain.com
# -------------------------
WECHAT_MINIPROGRAM_APP_ID=wxe37440e105a2bc19
WECHAT_MINIPROGRAM_APP_SECRET=
WECHAT_MINIPROGRAM_LOGIN_ENABLED=false
WECHAT_MINIPROGRAM_TEST_MODE=true
WECHAT_MINIPROGRAM_REQUEST_DOMAIN=
WECHAT_MINIPROGRAM_UPLOAD_DOMAIN=
WECHAT_MINIPROGRAM_SOCKET_DOMAIN=
WECHAT_CODE2SESSION_BASE_URL=https://api.weixin.qq.com


# -------------------------
# Local opaque session tokens
# Used for mini-program / local auth bridge sessions
# -------------------------
LOCAL_ACCESS_TOKEN_TTL_MINUTES=120
LOCAL_REFRESH_TOKEN_TTL_DAYS=30


# -------------------------
# Native App placeholders
# Not required right now, but reserved for later Expo / iOS / Android work
# -------------------------
EXPO_PUBLIC_API_BASE_URL=
EXPO_PROJECT_ID=
IOS_BUNDLE_ID=
ANDROID_PACKAGE_NAME=
APP_STORE_DISPLAY_NAME=AI Wardrobe
