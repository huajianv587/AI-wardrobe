APP_ENV=production
COMPOSE_PROJECT_NAME=ai-wardrobe-prod
AI_WARDROBE_RELEASE_TAG=latest
GATEWAY_HTTP_PORT=80
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
DEPLOY_BACKUP_ROOT=./infra/runtime/backups
DEPLOY_BACKUP_RETENTION_DAYS=14

NEXT_PUBLIC_APP_URL=https://www.aiwardrobes.com
NEXT_PUBLIC_API_BASE_URL=https://api.aiwardrobes.com
BACKEND_PUBLIC_BASE_URL=https://api.aiwardrobes.com
BACKEND_CORS_ORIGINS=https://www.aiwardrobes.com,https://aiwardrobes.com

DATABASE_URL=
LOCAL_STORAGE_ROOT=./data/assets
MODEL_TRAINING_DIR=./model_training
FASHION_MODEL_ROOT=./data/models/fashion
FASHION_DETECTOR_WEIGHTS=./data/models/fashion/yolo/yolo26n.pt
FASHION_SAM2_CHECKPOINT=./data/models/fashion/sam2/sam2.1_hiera_small.pt
FASHION_CLIP_MODEL_ID=patrickjohncyh/fashion-clip

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=wardrobe-assets
SUPABASE_SYNC_TABLE=clothing_items

R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
R2_PRESIGN_EXPIRES_SECONDS=900

REDIS_URL=redis://redis:6379/0
TASK_QUEUE_ENABLED=true
TASK_QUEUE_EAGER=false
TASK_QUEUE_RESULT_TTL_SECONDS=1800
TASK_QUEUE_DEFAULT_TIMEOUT_SECONDS=900
TASK_QUEUE_IMAGE_CLEANUP_TIMEOUT_SECONDS=1200
TASK_QUEUE_SMART_TIMEOUT_SECONDS=1500

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MULTIMODAL_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MULTIMODAL_MODEL=deepseek-chat
MULTIMODAL_READER_API_URL=
MULTIMODAL_READER_API_KEY=
MULTIMODAL_READER_RUN_MODE=proxy
MULTIMODAL_READER_UPSTREAM_URL=http://vllm-multimodal:8000/v1
MULTIMODAL_READER_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
# When serving your own recommender through the vLLM stack below,
# point the backend at the internal service or your public gateway.
LLM_RECOMMENDER_API_URL=http://vllm-recommender:8000/v1
LLM_RECOMMENDER_API_KEY=
LLM_RECOMMENDER_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
LLM_RECOMMENDER_FALLBACK_API_URL=
LLM_RECOMMENDER_FALLBACK_API_KEY=
LLM_RECOMMENDER_FALLBACK_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
VLLM_BASE_URL=http://vllm-multimodal:8000/v1
QWEN_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
HF_TOKEN=
VLLM_DOCKER_IMAGE=vllm/vllm-openai
VLLM_DOCKER_TAG=latest
VLLM_GENERATION_CONFIG_MODE=vllm
MODEL_GATEWAY_PORT=8088
VLLM_RECOMMENDER_PORT=8001
VLLM_RECOMMENDER_MODEL_PATH=/models/llm-recommender
VLLM_RECOMMENDER_SERVED_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
VLLM_RECOMMENDER_MAX_MODEL_LEN=4096
VLLM_RECOMMENDER_GPU_MEMORY_UTILIZATION=0.92
VLLM_RECOMMENDER_DTYPE=bfloat16
VLLM_MULTIMODAL_PORT=8002
VLLM_MULTIMODAL_MODEL_PATH=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_MULTIMODAL_SERVED_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_MULTIMODAL_MAX_MODEL_LEN=8192
VLLM_MULTIMODAL_GPU_MEMORY_UTILIZATION=0.90
VLLM_MULTIMODAL_DTYPE=bfloat16
VLLM_MULTIMODAL_LIMIT_MM_PER_PROMPT=image=1
VIRTUAL_TRYON_API_URL=https://api.replicate.com/v1/predictions
VIRTUAL_TRYON_API_KEY=
VIRTUAL_TRYON_FALLBACK_API_URL=
VIRTUAL_TRYON_FALLBACK_API_KEY=
VIRTUAL_TRYON_REPLICATE_VERSION=
VIRTUAL_TRYON_REPLICATE_INPUT_TEMPLATE={"human_img":"{{person_image_url}}","garm_img":"{{primary_garment_url}}","garment_des":"{{prompt_or_scene}}","category":"{{replicate_category}}","crop":false,"force_dc":"{{replicate_force_dc}}"}
TARO_APP_API_BASE_URL=https://api.aiwardrobes.com
EXPO_PUBLIC_API_BASE_URL=https://api.aiwardrobes.com

MODEL_USE_LOCAL_DEFAULT=true
MODEL_USE_LOCAL_LLM_RECOMMENDER=false
MODEL_USE_LOCAL_IMAGE_CLEANUP=true
MODEL_USE_LOCAL_CLASSIFIER=true
MODEL_USE_LOCAL_MULTIMODAL_READER=true
MODEL_USE_LOCAL_VIRTUAL_TRYON=false
MODEL_USE_LOCAL_PRODUCT_RENDERER=true
MODEL_USE_LOCAL_AVATAR_BUILDER=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Wardrobe
SMTP_USE_TLS=true
SMTP_USE_SSL=false

ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_SUBJECT_PREFIX=[AI Wardrobe Alert]
ALERT_ON_UNCAUGHT_EXCEPTIONS=true
ALERT_DEDUPE_WINDOW_SECONDS=900

LOG_LEVEL=INFO
LOG_JSON=true
HEALTH_PROBE_TIMEOUT_SECONDS=5

RATE_LIMIT_ENABLED=true
RATE_LIMIT_USE_REDIS=true
RATE_LIMIT_REDIS_PREFIX=ai-wardrobe:ratelimit
RATE_LIMIT_DEFAULT_REQUESTS=240
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
RATE_LIMIT_HEAVY_REQUESTS=24
RATE_LIMIT_HEAVY_WINDOW_SECONDS=300
