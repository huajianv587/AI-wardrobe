{
  // Keep the explorer responsive by avoiding huge generated directories.
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.pytest_cache/**": true,
    "**/__pycache__/**": true,
    "**/.next/**": true,
    "**/dist/**": true,
    "**/out/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/backend/data/**": true,
    "**/model_training/checkpoints/**": true,
    "**/model_training/outputs/**": true
  },
  // Hide bulky or generated folders that do not need constant browsing.
  "files.exclude": {
    "**/.pytest_cache": true,
    "**/__pycache__": true,
    "**/.next": true,
    "**/dist": true,
    "**/out": true,
    "**/node_modules": true,
    "**/.venv": true,
    "**/venv": true
  },
  // Reduce indexing cost so new source files show up faster.
  "search.exclude": {
    "**/.git": true,
    "**/.pytest_cache": true,
    "**/__pycache__": true,
    "**/.next": true,
    "**/dist": true,
    "**/out": true,
    "**/node_modules": true,
    "**/.venv": true,
    "**/venv": true,
    "**/backend/data": true,
    "**/model_training/checkpoints": true,
    "**/model_training/outputs": true
  },
  "explorer.autoReveal": true,
  "git.autorefresh": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1200
}
