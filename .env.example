# AI Wardrobe production-ready template for the current repo
# Copy this file to `.env`.
# The lines that are intentionally left empty are the ones you still need to fill by hand.

# -------------------------
# App
# -------------------------
APP_NAME=AI Wardrobe API
APP_ENV=production


# -------------------------
# Web
# NEXT_PUBLIC_API_BASE_URL and BACKEND_PUBLIC_BASE_URL must point to your live backend API.
# If you use a reverse proxy on the same domain, both can be the same HTTPS origin.
# -------------------------
NEXT_PUBLIC_APP_NAME=AI Wardrobe
NEXT_PUBLIC_APP_URL=https://www.aiwardrobes.com
NEXT_PUBLIC_API_BASE_URL=
BACKEND_PUBLIC_BASE_URL=
BACKEND_CORS_ORIGINS=https://www.aiwardrobes.com,https://aiwardrobes.com,http://localhost:3000,http://127.0.0.1:3000


# -------------------------
# Database
# Recommended Supabase format:
# postgresql+psycopg://postgres:[YOUR_DB_PASSWORD]@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
# -------------------------
DATABASE_URL=


# -------------------------
# Local storage + model paths
# These paths are correct for the current start-backend.cmd flow, which starts inside /backend.
# -------------------------
LOCAL_STORAGE_ROOT=./data/assets
MODEL_TRAINING_DIR=../model_training
FASHION_MODEL_ROOT=../data/models/fashion
FASHION_DETECTOR_WEIGHTS=../data/models/fashion/yolo/yolo26n.pt
FASHION_SAM2_CHECKPOINT=../data/models/fashion/sam2/sam2.1_hiera_small.pt
FASHION_CLIP_MODEL_ID=patrickjohncyh/fashion-clip


# -------------------------
# Supabase
# Run infra/supabase/productized_schema.sql after filling these.
# -------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=wardrobe-assets
SUPABASE_SYNC_TABLE=clothing_items


# -------------------------
# Cloudflare R2
# Required if you want production asset storage on R2 instead of local disk.
# -------------------------
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
R2_PRESIGN_EXPIRES_SECONDS=900


# -------------------------
# Cache / queue
# -------------------------
REDIS_URL=redis://localhost:6379/0


# -------------------------
# Multimodal / fallback provider keys
# Fill at least one external provider if VLLM_BASE_URL is not configured.
# -------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MULTIMODAL_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MULTIMODAL_MODEL=deepseek-chat
MULTIMODAL_REQUEST_TIMEOUT_SECONDS=20


# -------------------------
# Optional local vLLM
# Leave VLLM_BASE_URL blank unless you deploy a local multimodal model endpoint.
# -------------------------
VLLM_BASE_URL=
QWEN_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct


# -------------------------
# Model routing
# Current recommended production behavior for this repo:
# - image cleanup prefers the local real segmentation chain
# - recommendation prefers a remote worker when provided
# - virtual try-on prefers a remote worker when provided
# -------------------------
MODEL_USE_LOCAL_DEFAULT=true
MODEL_USE_LOCAL_LLM_RECOMMENDER=false
MODEL_USE_LOCAL_IMAGE_CLEANUP=true
MODEL_USE_LOCAL_CLASSIFIER=true
MODEL_USE_LOCAL_MULTIMODAL_READER=true
MODEL_USE_LOCAL_VIRTUAL_TRYON=false
MODEL_USE_LOCAL_PRODUCT_RENDERER=true
MODEL_USE_LOCAL_AVATAR_BUILDER=true


# -------------------------
# Image cleanup
# Leave the worker URL commented unless you deploy your own compatible cleanup worker.
# The current backend can already do local cleanup with YOLO + SCHP + SAM2.
# -------------------------
AI_CLEANUP_TIMEOUT_SECONDS=45
# AI_CLEANUP_API_URL=https://cleanup.yourdomain.com/process
# AI_CLEANUP_API_KEY=


# -------------------------
# Remote AI workers
# Keep the commented optional workers disabled until you actually deploy them.
# LLM_RECOMMENDER_API_URL is needed for a real remote recommendation chain.
# VIRTUAL_TRYON_API_URL is needed for a real generative try-on chain.
# If you point VIRTUAL_TRYON_API_URL to Replicate `/v1/predictions`,
# also fill VIRTUAL_TRYON_REPLICATE_VERSION and usually VIRTUAL_TRYON_REPLICATE_INPUT_TEMPLATE.
# Example template:
# {"human_img":"{{person_image_url}}","garm_img":"{{primary_garment_url}}","garment_des":"{{prompt_or_scene}}","category":"{{replicate_category}}","crop":false,"force_dc":"{{replicate_force_dc}}"}
# -------------------------
AI_DEMO_ADAPTER_TIMEOUT_SECONDS=8
LLM_RECOMMENDER_API_URL=
LLM_RECOMMENDER_API_KEY=
LLM_RECOMMENDER_MODEL_NAME=
# IMAGE_PROCESSOR_API_URL=https://image-processor.yourdomain.com/infer
# CLASSIFIER_API_URL=https://classifier.yourdomain.com/infer
# MULTIMODAL_READER_API_URL=https://reader.yourdomain.com/infer
VIRTUAL_TRYON_API_URL=
VIRTUAL_TRYON_API_KEY=
VIRTUAL_TRYON_REPLICATE_VERSION=
VIRTUAL_TRYON_REPLICATE_INPUT_TEMPLATE={"human_img":"{{person_image_url}}","garm_img":"{{primary_garment_url}}","garment_des":"{{prompt_or_scene}}","category":"{{replicate_category}}","crop":false,"force_dc":"{{replicate_force_dc}}"}
VIRTUAL_TRYON_POLL_TIMEOUT_SECONDS=300
VIRTUAL_TRYON_POLL_INTERVAL_SECONDS=2
# PRODUCT_RENDERER_API_URL=https://product-renderer.yourdomain.com/infer
# AVATAR_BUILDER_API_URL=https://avatar-builder.yourdomain.com/infer


# -------------------------
# Local virtual try-on assets
# Uncomment only if you wire a local try-on worker or custom checkpoint loader later.
# -------------------------
# VIRTUAL_TRYON_MODEL_ROOT=../data/models/virtual-tryon


# -------------------------
# Session + password reset
# -------------------------
LOCAL_ACCESS_TOKEN_TTL_MINUTES=120
LOCAL_REFRESH_TOKEN_TTL_DAYS=30
LOCAL_PASSWORD_RESET_TTL_MINUTES=30


# -------------------------
# SMTP
# The current code reads SMTP_HOST, not SMTP_SERVER.
# -------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AI Wardrobe
SMTP_USE_TLS=true
SMTP_USE_SSL=false


# -------------------------
# Mini Program / Mobile
# Not required for the current web-first production launch.
# Uncomment and fill only when you are ready to ship mini-program or app builds.
# -------------------------
# TARO_APP_API_BASE_URL=https://api.yourdomain.com
WECHAT_MINIPROGRAM_LOGIN_ENABLED=false
WECHAT_MINIPROGRAM_TEST_MODE=true
WECHAT_CODE2SESSION_BASE_URL=https://api.weixin.qq.com
# WECHAT_MINIPROGRAM_APP_ID=
# WECHAT_MINIPROGRAM_APP_SECRET=
# WECHAT_MINIPROGRAM_REQUEST_DOMAIN=https://api.yourdomain.com
# WECHAT_MINIPROGRAM_UPLOAD_DOMAIN=
# WECHAT_MINIPROGRAM_SOCKET_DOMAIN=
# EXPO_PUBLIC_API_BASE_URL=https://api.yourdomain.com
# EXPO_PROJECT_ID=
# IOS_BUNDLE_ID=
# ANDROID_PACKAGE_NAME=
APP_STORE_DISPLAY_NAME=AI Wardrobe
