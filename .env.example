# =========================
# AI Wardrobe Environment
# Copy this file to `.env`
# Replace every `YOUR_*` / `your-*` placeholder before production use.
# =========================

# -------------------------
# App
# -------------------------
APP_NAME=ai-wardrobe
APP_ENV=development


# -------------------------
# Frontend / Web
# Development: keep localhost
# Production: replace with your real HTTPS domain
# -------------------------
NEXT_PUBLIC_APP_NAME=AI Wardrobe
NEXT_PUBLIC_APP_URL=https://your-web-domain.com
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com


# -------------------------
# Backend
# BACKEND_PUBLIC_BASE_URL is the public HTTPS address of your backend API.
# DATABASE_URL is the source of truth for your app data.
# Recommended production / Supabase Postgres format:
# DATABASE_URL=postgresql+psycopg://postgres:[YOUR_DB_PASSWORD]@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
# Local fallback format:
# DATABASE_URL=sqlite:///./data/ai_wardrobe.db
# -------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_BASE_URL=https://api.yourdomain.com
BACKEND_CORS_ORIGINS=https://your-web-domain.com,https://www.your-web-domain.com
DATABASE_URL=postgresql+psycopg://postgres:[YOUR_DB_PASSWORD]@db.your-project-ref.supabase.co:5432/postgres?sslmode=require


# -------------------------
# Mini Program / Mobile Client
# TARO_APP_API_BASE_URL should point to your backend API.
# Production should be HTTPS and normally match BACKEND_PUBLIC_BASE_URL.
# -------------------------
TARO_APP_API_BASE_URL=https://api.yourdomain.com


# -------------------------
# Local-first storage
# -------------------------
LOCAL_STORAGE_ROOT=./backend/data/assets
MODEL_TRAINING_DIR=./model_training


# -------------------------
# Supabase
# Fill DATABASE_URL with the Supabase Postgres connection string above.
# Then run `infra/supabase/productized_schema.sql` in Supabase SQL Editor.
# Fill ANON KEY and SERVICE ROLE KEY from:
# Supabase Dashboard -> Project Settings -> API
# -------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=wardrobe-assets
SUPABASE_SYNC_TABLE=clothing_items


# -------------------------
# Cache / Queue / Future async expansion
# -------------------------
REDIS_URL=redis://localhost:6379/0


# -------------------------
# Cloudflare R2 object storage
# R2_PUBLIC_BASE_URL should be a public custom domain or the bucket's r2.dev base URL.
# Example:
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_BUCKET=ai-wardrobe
# R2_PUBLIC_BASE_URL=https://images.yourdomain.com
# -------------------------
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
R2_PRESIGN_EXPIRES_SECONDS=900


# -------------------------
# Optional local S3-compatible storage for development experiments
# Keep blank if you are not using MinIO locally.
# -------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ai-wardrobe


# -------------------------
# LLM / model platform basics
# The recognition chain is:
# 1. local multimodal model
# 2. retry once
# 3. OpenAI
# 4. retry once
# 5. DeepSeek
#
# If your current development machine has no GPU, leave `VLLM_BASE_URL` blank.
# The backend will skip the local first layer and go straight to the external fallback chain.
#
# When you deploy to a GPU machine such as a 5090 box, fill:
# VLLM_BASE_URL=http://127.0.0.1:8001/v1
#
# For image understanding, the local first layer must be a multimodal model,
# not a text-only instruct model.
# -------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MULTIMODAL_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MULTIMODAL_MODEL=deepseek-chat
MULTIMODAL_REQUEST_TIMEOUT_SECONDS=20

# Local vLLM service
VLLM_HOST=127.0.0.1
VLLM_PORT=8001
VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_CPU_KVCACHE_SPACE=40
VLLM_CPU_NUM_OF_RESERVED_CPU=1
VLLM_BASE_URL=
QWEN_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct


# -------------------------
# Model routing
# Source of truth can stay in backend/core/local_model.py
# MODEL_USE_LOCAL_DEFAULT=true means:
# prefer local logic unless a feature-specific override says otherwise
#
# Important:
# if you want the real remote cleanup worker to run,
# uncomment `MODEL_USE_LOCAL_IMAGE_CLEANUP=false`
#
# If you want .env to hard override one feature, uncomment the line you need.
# Example:
# MODEL_USE_LOCAL_LLM_RECOMMENDER=false
# -------------------------
MODEL_USE_LOCAL_DEFAULT=true
# MODEL_USE_LOCAL_LLM_RECOMMENDER=false
MODEL_USE_LOCAL_IMAGE_CLEANUP=false
# MODEL_USE_LOCAL_CLASSIFIER=false
# MODEL_USE_LOCAL_MULTIMODAL_READER=false
# MODEL_USE_LOCAL_VIRTUAL_TRYON=false
# MODEL_USE_LOCAL_PRODUCT_RENDERER=false
# MODEL_USE_LOCAL_AVATAR_BUILDER=false


# -------------------------
# AI cleanup pipeline
# Used for image cleanup / background removal adapter
# -------------------------
AI_CLEANUP_API_URL=https://your-cleanup-worker.example.com/process
AI_CLEANUP_API_KEY=YOUR_CLEANUP_WORKER_KEY
AI_CLEANUP_TIMEOUT_SECONDS=45


# -------------------------
# Weather
# Built-in tomorrow assistant currently uses Open-Meteo by default.
# No API key is required for the current demo flow.
# -------------------------


# -------------------------
# API-first AI worker adapters
# Fill these after your own workers are deployed.
# If blank, corresponding features fall back to local/demo logic.
# -------------------------
AI_DEMO_ADAPTER_TIMEOUT_SECONDS=8
LLM_RECOMMENDER_API_URL=
IMAGE_PROCESSOR_API_URL=
CLASSIFIER_API_URL=
MULTIMODAL_READER_API_URL=
VIRTUAL_TRYON_API_URL=
PRODUCT_RENDERER_API_URL=
AVATAR_BUILDER_API_URL=


# -------------------------
# Stage-1 local worker model settings
# These are consumed by the worker containers, not by the main backend.
# -------------------------
LLM_RECOMMENDER_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
LLM_RECOMMENDER_MODEL_PATH=/app/model_training/checkpoints/llm-recommender
LLM_RECOMMENDER_DATASET_DIR=/app/model_training/datasets/llm-recommender
LLM_RECOMMENDER_RUN_MODE=heuristic

IMAGE_PROCESSOR_PRIMARY_MODEL=briaai/RMBG-2.0
IMAGE_PROCESSOR_UPSCALER_MODEL=xinntao/Real-ESRGAN
IMAGE_PROCESSOR_MODEL_PATH=/app/model_training/checkpoints/image-processor
IMAGE_PROCESSOR_RUN_MODE=passthrough


# -------------------------
# WeChat Mini Program
# Fill AppID / AppSecret from:
# 微信公众平台 -> 开发 -> 开发管理 -> 开发设置
#
# Important:
# WECHAT_MINIPROGRAM_REQUEST_DOMAIN should normally be your backend API HTTPS domain,
# not just the Supabase URL.
# Example production value:
# WECHAT_MINIPROGRAM_REQUEST_DOMAIN=https://api.yourdomain.com
# -------------------------
WECHAT_MINIPROGRAM_APP_ID=YOUR_WECHAT_MINIPROGRAM_APP_ID
WECHAT_MINIPROGRAM_APP_SECRET=YOUR_WECHAT_MINIPROGRAM_APP_SECRET
WECHAT_MINIPROGRAM_LOGIN_ENABLED=false
WECHAT_MINIPROGRAM_TEST_MODE=true
WECHAT_MINIPROGRAM_REQUEST_DOMAIN=https://api.yourdomain.com
WECHAT_MINIPROGRAM_UPLOAD_DOMAIN=
WECHAT_MINIPROGRAM_SOCKET_DOMAIN=
WECHAT_CODE2SESSION_BASE_URL=https://api.weixin.qq.com


# -------------------------
# Local opaque session tokens
# Used for mini-program / local auth bridge sessions
# -------------------------
LOCAL_ACCESS_TOKEN_TTL_MINUTES=120
LOCAL_REFRESH_TOKEN_TTL_DAYS=30
LOCAL_PASSWORD_RESET_TTL_MINUTES=30


# -------------------------
# Password reset email delivery
# BACKEND_PUBLIC_BASE_URL must be correct, because reset links are generated from it.
# Common SMTP providers:
# Resend SMTP / SendGrid SMTP / Mailgun SMTP / enterprise mailbox SMTP
# -------------------------
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=YOUR_SMTP_USERNAME
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=AI Wardrobe
SMTP_USE_TLS=true
SMTP_USE_SSL=false


# -------------------------
# Native App placeholders
# Not required right now, but reserved for later Expo / iOS / Android work
# -------------------------
EXPO_PUBLIC_API_BASE_URL=
EXPO_PROJECT_ID=
IOS_BUNDLE_ID=
ANDROID_PACKAGE_NAME=
APP_STORE_DISPLAY_NAME=AI Wardrobe
